# HeavyLift CRM — Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit the real .env to git

SECRET_KEY=replace-with-a-long-random-string-here
DEBUG=False
DB_ENGINE=postgres
DB_ALLOW_SQLITE_FALLBACK=False
INIT_DB_ON_START=False
BOOTSTRAP_USERNAME=
BOOTSTRAP_EMAIL=
BOOTSTRAP_PASSWORD=
BOOTSTRAP_ROLE=developer
HTTPS_REDIRECT=True
TRUST_PROXY_HEADERS=True
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME_HOURS=12
SESSION_BIND_IP=True
SESSION_BIND_USER_AGENT=True
HSTS_MAX_AGE=31536000
SOCKETIO_PING_INTERVAL=25
SOCKETIO_PING_TIMEOUT=20
SOCKETIO_REQUIRE_CSRF_AUTH=True
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_MINUTES=15
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_MAX_REQUESTS=60
MESSAGE_SEND_RATE_LIMIT_MAX_REQUESTS=10
BCRYPT_ROUNDS=12
WEBSOCKET_REFRESH_WINDOW_SECONDS=10
WEBSOCKET_REFRESH_MAX_MESSAGES=5
WEBSOCKET_MAX_INVALID_MESSAGES=3

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inquiry_db
DB_USER=postgres
DB_PASS=replace-with-db-password

# WhatsApp Business API (optional — leave blank to use wa.me links)
WA_API_URL=
WA_API_TOKEN=
WA_PHONE_ID=

# Server
PORT=5000

# Optional local TLS certs for direct HTTPS from Flask during development
SSL_CERT_FILE=
SSL_KEY_FILE=
