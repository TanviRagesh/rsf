{
  "info": {
    "name": "HeavyLift CRM API - Examples",
    "_postman_id": "heavylift-example-collection",
    "description": "Minimal Postman collection with login and lead creation examples.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api","v1","auth","login"]
        }
      }
    },
    {
      "name": "Leads - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Ravi Kumar\",\n  \"mobile\": \"+919876543210\",\n  \"course_id\": 2,\n  \"location_id\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/leads",
          "host": ["{{baseUrl}}"],
          "path": ["api","v1","leads"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "token", "value": "" }
  ]
}
